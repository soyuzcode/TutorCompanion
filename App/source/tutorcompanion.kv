<HelloWorld>

MDFloatLayout:
    md_bg_color: 0/255, 53/255, 102/255, 1

    MDLabel:
        text: "[b]TUTOR COMPANION[/b]"
        halign: "center"
        markup: True
        pos_hint: {"center_x": 0.5, "center_y": 0.85}
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        font_style: "Display"
        role: "medium"

    MDTextField:
        id: full_name
        mode: "filled"
        size_hint_x: 0.85
        pos_hint: {"center_x": 0.5, "center_y": 0.7}

        MDTextFieldHintText:
            text: "Nombre Completo"

        MDTextFieldLeadingIcon:
            icon: "account"

    MDTextField:
        id: user_email
        mode: "filled"
        size_hint_x: 0.85
        pos_hint: {"center_x": 0.5, "center_y": 0.58}

        MDTextFieldHintText:
            text: "Correo Electrónico"

        MDTextFieldLeadingIcon:
            icon: "email"

    MDLabel:
        text: "¿Qué rol deseas tener?"
        halign: "center"
        pos_hint: {"center_y": 0.48}
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        font_style: "Title"

    MDButton:
        style: "elevated"
        pos_hint: {"center_x": 0.3, "center_y": 0.4}

        on_release:
            app.imprimir_datos(
            "Estudiante",
            full_name.text
            )

        MDButtonText:
            text: "Estudiante"

    MDButton:
        style: "filled"
        pos_hint: {"center_x": 0.7, "center_y": 0.4}

        on_release:
            app.imprimir_datos(
            "Tutor",
            full_name.text
            )

        MDButtonText:
            text: "Ser Tutor"