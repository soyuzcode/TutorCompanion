<HelloWorld>:

    MDFloatLayout:
        md_bg_color: 0/255, 53/255, 102/255, 1

        MDLabel:
            text: "[b]TUTOR COMPANION[/b]"
            halign: "center"
            markup: True
            pos_hint: {"center_x": 0.5, "center_y": 0.85}
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            font_style: "H4"

        MDTextField:
            id: full_name
            hint_text: "Nombre Completo"
            icon_right: "account"
            mode: "fill"
            size_hint_x: 0.85
            pos_hint: {"center_x": 0.5, "center_y": 0.7}

        MDTextField:
            id: user_email
            hint_text: "Correo Electrónico"
            icon_right: "email"
            mode: "fill"
            size_hint_x: 0.85
            pos_hint: {"center_x": 0.5, "center_y": 0.58}

        MDLabel:
            text: "¿Qué rol deseas tener?"
            halign: "center"
            pos_hint: {"center_y": 0.48}
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            font_style: "H6"

        MDRaisedButton:
            text: "Estudiante"
            pos_hint: {"center_x": 0.3, "center_y": 0.4}

            on_release:
                app.imprimir_datos(
                "Estudiante",
                full_name.text
                )

        MDFillRoundFlatButton:
            text: "Ser Tutor"
            pos_hint: {"center_x": 0.7, "center_y": 0.4}

            on_release:
                app.imprimir_datos(
                "Tutor",
                full_name.text
                )