<HelloWorld>:

    MDFloatLayout:
        md_bg_color: 0.05, 0.08, 0.15, 1

        MDIcon:
            icon: "school"
            font_size: "85sp"
            pos_hint: {"center_x": 0.5, "center_y": 0.85}
            theme_text_color: "Custom"
            text_color: 0.3, 0.8, 1, 1

        MDLabel:
            text: "Tutor Companion"
            halign: "center"
            pos_hint: {"center_y": 0.75}
            font_style: "H4"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        MDLabel:
            text: "Powered by Key Code®"
            halign: "center"
            pos_hint: {"center_y": 0.70}
            theme_text_color: "Custom"
            text_color: 0.6, 0.6, 0.6, 1

        MDCard:
            size_hint: 0.88, 0.42
            pos_hint: {"center_x": 0.5, "center_y": 0.38}
            padding: "25dp"
            radius: [28, 28, 28, 28]
            elevation: 12
            md_bg_color: 0.1, 0.12, 0.2, 1

            BoxLayout:
                orientation: "vertical"
                spacing: "20dp"

                MDTextField:
                    id: full_name
                    hint_text: "Nombre / Correo / Código KEY"
                    helper_text: "KEY_123456"
                    helper_text_mode: "on_focus"
                    icon_right: "email"
                    mode: "rectangle"
                    size_hint_y: None
                    height: "50dp"

                MDTextField:
                    id: password
                    hint_text: "Contraseña"
                    helper_text: "Ingresa tu contraseña"
                    helper_text_mode: "on_focus"
                    password: True
                    icon_right: "lock"
                    mode: "rectangle"
                    size_hint_y: None
                    height: "50dp"

                Widget:

                MDFillRoundFlatButton:
                    text: "LOGIN"
                    font_size: "16sp"
                    pos_hint: {"center_x": 0.5}
                    size_hint_x: 0.8

                    on_release:
                        app.on_login(full_name.text, password.text)

        MDLabel:
            text: "Key Institute®"
            halign: "center"
            pos_hint: {"center_y": 0.04}
            theme_text_color: "Custom"
            text_color: 0.4, 0.4, 0.4, 1
            font_style: "Caption"