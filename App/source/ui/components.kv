# =========================================================
# ACTION CARD
# =========================================================

<ActionCard@MDCard>

    icon: ""
    title: ""
    subtitle: ""

    size_hint_y: None
    height: dp(110)

    radius: [20]
    elevation: 0
    padding: dp(18)

    md_bg_color: 0.12, 0.13, 0.18, 1

    MDBoxLayout:
        spacing: dp(15)
        adaptive_height: True
        pos_hint: {"center_y": 0.5}

        MDIcon:
            icon: root.icon
            font_size: "38sp"

            size_hint_x: None
            width: dp(50)

            theme_text_color: "Custom"
            text_color: 0.3, 0.8, 1, 1

        MDBoxLayout:
            orientation: "vertical"

            Widget:

            MDLabel:
                text: root.title
                bold: True

                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            MDLabel:
                text: root.subtitle
                font_size: "12sp"

                theme_text_color: "Custom"
                text_color: 0.7, 0.7, 0.7, 1

            Widget:


# =========================================================
# TUTORIA CARD
# =========================================================

<TutoriaCard>

    size_hint_y: None
    height: dp(80)

    radius: [20]
    elevation: 0
    padding: dp(18)

    md_bg_color: 0.12, 0.13, 0.18, 1

    MDBoxLayout:
        orientation: "vertical"
        spacing: dp(5)
        pos_hint: {"center_y": 0.5}

        MDLabel:
            text: root.materia
            bold: True
            font_size: "18sp"

            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        MDLabel:
            text: root.fecha

            theme_text_color: "Custom"
            text_color: 0.7, 0.7, 0.7, 1


# =========================================================
# TUTOR CARD
# =========================================================

<TutorCard>

    position: ""
    name: ""
    rating: "0"

    size_hint_y: None
    height: dp(85)

    radius: [20]
    elevation: 0
    padding: dp(18)

    md_bg_color: 0.12, 0.13, 0.18, 1

    MDBoxLayout:
        spacing: dp(15)

        MDLabel:
            text: root.position
            bold: True

            size_hint_x: None
            width: dp(30)

            theme_text_color: "Custom"
            text_color: 0.3, 0.8, 1, 1

        MDLabel:
            text: root.name

            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        Widget:

        MDLabel:
            text: root.rating

            theme_text_color: "Custom"
            text_color: 1, 0.8, 0.2, 1


# =========================================================
# FEATURE CARD
# =========================================================

<FeatureCard@MDCard>

    icon: ""
    title: ""

    size_hint_y: None
    height: dp(80)

    radius: [20]
    elevation: 0
    padding: dp(20)

    md_bg_color: 0.12, 0.13, 0.18, 1

    MDBoxLayout:
        orientation: "horizontal"
        spacing: dp(15)
        adaptive_height: True
        pos_hint: {"center_y": 0.5, "center_x": 0.5}

        Widget:

        MDIcon:
            icon: root.icon
            font_size: "30sp"
            size_hint_x: None
            width: self.texture_size[0]

            theme_text_color: "Custom"
            text_color: 0.3, 0.8, 1, 1

        MDLabel:
            text: root.title
            bold: True
            adaptive_width: True

            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        Widget:


# =========================================================
# SOLICITUD CARD
# =========================================================

<SolicitudCard>
    author: ""
    author_pfp: ""
    topic: ""
    materia: ""
    solicitud_id: ""
    data_original: None

    size_hint_y: None
    height: dp(115)

    radius: [20]
    elevation: 0
    padding: dp(15)

    md_bg_color: 0.12, 0.13, 0.18, 1

    MDBoxLayout:
        spacing: dp(10)

        FitImage:
            source: root.author_pfp if root.author_pfp else ""
            size_hint_x: None
            width: dp(45)
            height: dp(45)
            radius: [23]

        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(4)

            MDLabel:
                text: root.author
                bold: True
                font_size: "15sp"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            MDLabel:
                text: root.topic
                font_size: "13sp"
                theme_text_color: "Custom"
                text_color: 0.85, 0.85, 0.9, 1

            MDLabel:
                text: "Solicita: " + root.materia
                font_size: "12sp"
                theme_text_color: "Custom"
                text_color: 0.7, 0.7, 0.7, 1

        MDBoxLayout:
            orientation: "vertical"
            size_hint_x: None
            width: dp(100)
            spacing: dp(5)

            MDRaisedButton:
                text: "Aceptar"
                size_hint_x: 1
                font_size: "10sp"
                on_release: app.sm.get_screen('dashboard').manejar_decision(root.solicitud_id, "accepted", root.data_original)

            MDRaisedButton:
                text: "Rechazar"
                size_hint_x: 1
                font_size: "10sp"
                on_release: app.sm.get_screen('dashboard').manejar_decision(root.solicitud_id, "rejected", root.data_original)


# =========================================================
# CALENDAR CARD
# =========================================================

<CalendarCard@MDCard>

    size_hint_y: None
    height: dp(260)

    radius: [20]
    elevation: 0
    padding: dp(15)

    md_bg_color: 0.12, 0.13, 0.18, 1

    MDBoxLayout:
        orientation: "vertical"
        spacing: dp(10)

        MDGridLayout:
            cols: 7
            adaptive_height: True
            spacing: dp(5)

            MDLabel:
                text: "S"
                halign: "center"

            MDLabel:
                text: "M"
                halign: "center"

            MDLabel:
                text: "T"
                halign: "center"

            MDLabel:
                text: "W"
                halign: "center"

            MDLabel:
                text: "T"
                halign: "center"

            MDLabel:
                text: "F"
                halign: "center"

            MDLabel:
                text: "S"
                halign: "center"

        MDGridLayout:
            cols: 7
            adaptive_height: True
            spacing: dp(5)

            MDLabel:
                text: "1"
                halign: "center"

            MDLabel:
                text: "2"
                halign: "center"

            MDLabel:
                text: "3"
                halign: "center"

            MDLabel:
                text: "4"
                halign: "center"

            MDLabel:
                text: "5"
                halign: "center"

            MDLabel:
                text: "6"
                halign: "center"

            MDLabel:
                text: "7"
                halign: "center"

# =========================================================
# IMPACT CARD
# =========================================================

<ImpactCard@MDCard>

    current_hours: 0
    total_hours: 0
    progress_value: 0

    size_hint_y: None
    height: dp(190)

    radius: [20]
    elevation: 0
    padding: dp(20)

    md_bg_color: 0.12, 0.13, 0.18, 1

    MDBoxLayout:
        orientation: "vertical"
        spacing: dp(12)

        MDLabel:
            text: "Tu impacto como tutor"
            bold: True

            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        MDLabel:
            text: "Key Hours: " + str(root.current_hours)

            theme_text_color: "Custom"
            text_color: 0.8, 0.8, 0.8, 1

        MDLabel:
            text: str(root.current_hours) + " / " + str(root.total_hours) + " horas"

            theme_text_color: "Custom"
            text_color: 0.6, 0.6, 0.6, 1

        MDProgressBar:
            value: root.progress_value

        MDLabel:
            text: str(root.progress_value) + "% completado"
            halign: "right"

            theme_text_color: "Custom"
            text_color: 0.5, 0.8, 1, 1

<TutorSelectCard>:
    orientation: "horizontal"
    size_hint_y: None
    height: "85dp"
    padding: "15dp"
    spacing: "15dp"
    radius: [20,20,20,20]
    
    # Cambio de color dinámico para notar que está seleccionado
    md_bg_color: (0.2, 0.4, 0.6, 1) if self.selected else (0.14, 0.16, 0.24, 1)
    
    ripple_behavior: True
    
    # Al hacer clic en cualquier parte de la tarjeta, activamos la selección
    on_release:
        for card in self.parent.children: card.selected = False
        self.selected = True

    FitImage:
        source: root.image
        size_hint_x: None
        width: "55dp"
        radius: [50]

    MDBoxLayout:
        orientation: "vertical"
        spacing: "3dp"
        MDLabel:
            text: root.name
            bold: True
            font_size: "16sp"
            theme_text_color: "Custom"
            text_color: 1,1,1,1
        MDLabel:
            text: f"⭐ {root.rating}"
            font_size: "13sp"
            theme_text_color: "Custom"
            text_color: 0.85,0.85,0.9,1

    MDCheckbox:
        group: "tutores"
        # Vinculamos el checkbox a la propiedad 'selected' de la tarjeta
        active: root.selected
        # Evitamos que el checkbox capture el clic de forma aislada 
        # para que siempre dispare el on_release de la tarjeta padre
        on_release: root.dispatch('on_release')