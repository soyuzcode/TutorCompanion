#:import dp kivy.metrics.dp

<SugerirTutoriaScreen>:

    MDFloatLayout:
        md_bg_color: 0.05, 0.08, 0.15, 1

        # =====================================================
        # HEADER
        # =====================================================

        MDIconButton:
            icon: "arrow-left"
            pos_hint: {"x": 0.02, "top": 0.98}
            theme_text_color: "Custom"
            text_color: 0.3, 0.8, 1, 1

            on_release:
                root.manager.transition.direction = "right"
                root.manager.current = "dashboard"

        MDLabel:
            text: "Sugerir Tutoría"
            font_style: "H4"
            bold: True
            halign: "center"
            pos_hint: {"center_y": 0.91}
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        MDLabel:
            text: "Describe el tema que necesitas reforzar 🎧"
            halign: "center"
            pos_hint: {"center_y": 0.865}
            font_size: "14sp"

            theme_text_color: "Custom"
            text_color: 0.65, 0.65, 0.7, 1

        MDIcon:
            icon: "comment-question-outline"
            font_size: "72sp"
            pos_hint: {"center_x": 0.5, "center_y": 0.77}

            theme_text_color: "Custom"
            text_color: 0.3, 0.8, 1, 1

        # =====================================================
        # FORM CONTAINER
        # =====================================================

        ScrollView:
            size_hint: 1, 0.63
            pos_hint: {"x": 0, "y": 0.08}

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                padding: dp(20)
                spacing: dp(15)

                MDCard:
                    orientation: "vertical"
                    adaptive_height: True

                    padding: dp(25)
                    spacing: dp(20)

                    radius: [32, 32, 32, 32]
                    elevation: 10

                    size_hint_x: 0.92
                    pos_hint: {"center_x": 0.5}

                    md_bg_color: 0.1, 0.12, 0.2, 1

                    # =========================================
                    # INPUTS
                    # =========================================

                    MDTextField:
                        id: txt_materia

                        hint_text: "Materia"
                        helper_text: "Ej. Matemática, Física, Programación"
                        helper_text_mode: "on_focus"

                        icon_right: "book-education"

                        mode: "fill"
                        radius: [18, 18, 18, 18]

                        size_hint_y: None
                        height: "60dp"

                        line_color_focus: 0.3, 0.8, 1, 1
                        icon_right_color_focus: 0.3, 0.8, 1, 1

                    MDTextField:
                        id: txt_tema

                        hint_text: "Tema específico"
                        helper_text: "Ej. Derivadas, SQL, Herencia"
                        helper_text_mode: "on_focus"

                        icon_right: "text-search"

                        mode: "fill"
                        radius: [18, 18, 18, 18]

                        size_hint_y: None
                        height: "60dp"

                        line_color_focus: 0.3, 0.8, 1, 1
                        icon_right_color_focus: 0.3, 0.8, 1, 1

                    MDTextField:
                        id: txt_descripcion

                        hint_text: "Describe tu dificultad"
                        helper_text: "Opcional"
                        helper_text_mode: "on_focus"

                        icon_right: "comment-text-outline"

                        multiline: True

                        mode: "fill"
                        radius: [18, 18, 18, 18]

                        size_hint_y: None
                        height: "130dp"

                        line_color_focus: 0.3, 0.8, 1, 1
                        icon_right_color_focus: 0.3, 0.8, 1, 1

                    Widget:
                        size_hint_y: None
                        height: dp(5)

                    # =========================================
                    # BUTTON
                    # =========================================

                    MDFillRoundFlatButton:
                        text: "PUBLICAR SUGERENCIA"
                        font_size: "15sp"

                        pos_hint: {"center_x": 0.5}

                        size_hint_x: 1
                        height: "52dp"

                        md_bg_color: 0.3, 0.8, 1, 1
                        text_color: 0.05, 0.08, 0.15, 1

                        on_release:
                            app.enviar_sugerencia(
                            txt_materia.text,
                            txt_tema.text,
                            txt_descripcion.text
                            )

        # =====================================================
        # FOOTER
        # =====================================================

        MDLabel:
            text: "Key Institute®"
            halign: "center"

            pos_hint: {"center_y": 0.03}

            font_size: "11sp"

            theme_text_color: "Custom"
            text_color: 0.45, 0.45, 0.5, 1