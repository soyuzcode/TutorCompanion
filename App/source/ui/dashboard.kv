#:import dp kivy.metrics.dp

<DashboardScreen>:

    MDFloatLayout:
        md_bg_color: 0.96, 0.97, 0.99, 1

        MDBoxLayout:
            orientation: "vertical"
            size_hint: 1, 0.2
            pos_hint: {"top": 1}
            padding: dp(25)
            spacing: dp(5)

            MDLabel:
                text: "Hola, Carlitos 👋"
                font_size: "30sp"
                bold: True
                adaptive_height: True
                theme_text_color: "Custom"
                text_color: 0.1, 0.1, 0.1, 1

            MDLabel:
                text: "Bienvenido de nuevo a Tutor Companion"
                adaptive_height: True
                theme_text_color: "Secondary"

        ScrollView:
            size_hint: 1, 0.8
            pos_hint: {"y": 0}

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: dp(20)
                padding: dp(20)

                MDGridLayout:
                    cols: 2
                    spacing: dp(15)
                    adaptive_height: True

                    MDCard:
                        radius: [24, 24, 24, 24]
                        elevation: 1
                        padding: dp(20)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(10)

                            MDIcon:
                                icon: "calendar"
                                font_size: "35sp"
                                theme_text_color: "Custom"
                                text_color: 0.1, 0.5, 1, 1

                            MDLabel:
                                text: "12"
                                font_size: "28sp"
                                bold: True
                                adaptive_height: True

                            MDLabel:
                                text: "Tutorías"
                                theme_text_color: "Secondary"

                    MDCard:
                        radius: [24, 24, 24, 24]
                        elevation: 1
                        padding: dp(20)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(10)

                            MDIcon:
                                icon: "book-open-variant"
                                font_size: "35sp"
                                theme_text_color: "Custom"
                                text_color: 0.2, 0.7, 0.4, 1

                            MDLabel:
                                text: "5"
                                font_size: "28sp"
                                bold: True
                                adaptive_height: True

                            MDLabel:
                                text: "Materias"
                                theme_text_color: "Secondary"

                MDLabel:
                    text: "Acciones rápidas"
                    font_size: "22sp"
                    bold: True
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 0.1, 0.1, 0.1, 1

                MDGridLayout:
                    cols: 2
                    spacing: dp(15)
                    adaptive_height: True

                    MDCard:
                        ripple_behavior: True
                        radius: [24, 24, 24, 24]
                        elevation: 1
                        padding: dp(20)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(10)

                            MDIcon:
                                icon: "account-search"
                                font_size: "40sp"
                                halign: "center"
                                theme_text_color: "Custom"
                                text_color: 0.4, 0.5, 1, 1

                            MDLabel:
                                text: "Buscar Tutor"
                                halign: "center"
                                bold: True

                    MDCard:
                        ripple_behavior: True
                        radius: [24, 24, 24, 24]
                        elevation: 1
                        padding: dp(20)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(10)

                            MDIcon:
                                icon: "clock-outline"
                                font_size: "40sp"
                                halign: "center"
                                theme_text_color: "Custom"
                                text_color: 0.1, 0.7, 0.8, 1

                            MDLabel:
                                text: "Mis Horarios"
                                halign: "center"
                                bold: True