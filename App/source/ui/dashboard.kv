#:import dp kivy.metrics.dp

# =========================================================
# DASHBOARD SCREEN
# =========================================================

<DashboardScreen>:

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.08, 0.09, 0.12, 1

        # =========================================================
        # HEADER START
        # =========================================================

        MDCard:
            size_hint_y: None
            height: dp(110)

            radius: [0, 0, 25, 25]
            elevation: 0
            padding: dp(20)

            md_bg_color: 0.05, 0.08, 0.16, 1

            MDBoxLayout:
                spacing: dp(20)

                # =================================================
                # USER SECTION START
                # =================================================

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_x: 0.3
                    spacing: dp(15)

                    MDIcon:
                        icon: "account-circle"
                        font_size: "52sp"

                        size_hint_x: None
                        width: dp(55)

                        theme_text_color: "Custom"
                        text_color: 0.3, 0.8, 1, 1

                    MDBoxLayout:
                        orientation: "vertical"

                        Widget:

                        MDLabel:
                            text: "Hola Carlitos 👋"
                            bold: True
                            adaptive_height: True

                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                        MDLabel:
                            text: "Rol: Estudiante"
                            adaptive_height: True

                            theme_text_color: "Custom"
                            text_color: 0.7, 0.7, 0.7, 1

                        Widget:

                # =================================================
                # USER SECTION END
                # =================================================


                # =================================================
                # CENTER TITLE START
                # =================================================

                MDBoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.5

                    Widget:

                    MDLabel:
                        text: "Compañeros Tutores"

                        halign: "center"
                        bold: True

                        font_size: "26sp"

                        adaptive_height: True

                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                    MDLabel:
                        text: "Tu red de aprendizaje"

                        halign: "center"

                        adaptive_height: True

                        theme_text_color: "Custom"
                        text_color: 0.7, 0.7, 0.7, 1

                    Widget:

                # =================================================
                # CENTER TITLE END
                # =================================================


                # =================================================
                # ACTIONS START
                # =================================================

                MDBoxLayout:
                    size_hint_x: 0.2

                    Widget:

                    MDIconButton:
                        icon: "bell-outline"

                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                    MDIconButton:
                        icon: "calendar"

                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                # =================================================
                # ACTIONS END
                # =================================================

        # =========================================================
        # HEADER END
        # =========================================================



        # =========================================================
        # BODY START
        # =========================================================

        MDBoxLayout:
            padding: dp(20)
            spacing: dp(20)

            # =====================================================
            # LEFT COLUMN START
            # =====================================================

            MDBoxLayout:
                id: contenedor_izquierdo  # <-- LE AGREGAMOS ESTE ID 
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.33

                MDLabel:
                    text: "¿Qué quieres hacer?"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                ActionCard:
                    icon: "calendar-plus"
                    title: "Sugerir Tutoría"
                    subtitle: "Pide ayuda en temas difíciles"

                ActionCard:
                    icon: "magnify"
                    title: "Buscar Tutorías"
                    subtitle: "Explora tutorías disponibles"

                ActionCard:
                    icon: "clock-outline"
                    title: "Mis Tutorías"
                    subtitle: "Revisa tus sesiones"

                MDLabel:
                    text: "Próximas Tutorías"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                # BORRAMOS las tarjetas viejas de Cálculo y Física de aquí.
                # Tu código se encargará de crearlas dinámicamente.

            # =====================================================
            # LEFT COLUMN END
            # =====================================================

            # =====================================================
            # CENTER COLUMN START
            # =====================================================

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.33

                MDLabel:
                    text: "Tutores Destacados"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True

                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                TutorCard:
                    position: "1"
                    name: "Andrea"

                TutorCard:
                    position: "2"
                    name: "Sebastián"

                TutorCard:
                    position: "3"
                    name: "María"

                TutorCard:
                    position: "4"
                    name: "Carlos"

                MDLabel:
                    text: "Feedback y progreso"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True

                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                MDGridLayout:
                    cols: 2
                    spacing: dp(15)
                    adaptive_height: True

                    FeatureCard:
                        icon: "star"
                        title: "Rating Tutor"

                    FeatureCard:
                        icon: "chart-bar"
                        title: "Estadísticas"

            # =====================================================
            # CENTER COLUMN END
            # =====================================================



            # =====================================================
            # RIGHT COLUMN START
            # =====================================================

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.34

                MDTextField:
                    hint_text: "Buscar tutorías..."

                    text_color_normal: 1,1,1,1
                    text_color_focus: 1,1,1,1

                    hint_text_color_normal: 0.7,0.7,0.7,1

                    line_color_focus: 0.3,0.8,1,1

                # =================================================
                # IMPACT CARD START
                # =================================================

                MDCard:
                    padding: dp(20)
                    radius: [20]
                    elevation: 0

                    md_bg_color: 0.12, 0.13, 0.18, 1

                    size_hint_y: None
                    height: dp(190)

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(12)

                        MDLabel:
                            text: "Tu impacto como tutor"
                            bold: True

                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                        MDLabel:
                            text: "Key Hours: 24"

                            theme_text_color: "Custom"
                            text_color: 0.8, 0.8, 0.8, 1

                        MDLabel:
                            text: "¡Sigue enseñando y canjea horas!"

                            theme_text_color: "Custom"
                            text_color: 0.6, 0.6, 0.6, 1

                        MDProgressBar:
                            value: 70

                        MDLabel:
                            text: "70% completado"
                            halign: "right"

                            theme_text_color: "Custom"
                            text_color: 0.5, 0.8, 1, 1

                # =================================================
                # IMPACT CARD END
                # =================================================


                MDLabel:
                    text: "Solicitudes"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True

                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                SolicitudCard:
                    name: "Luis"
                    materia: "Álgebra"

                SolicitudCard:
                    name: "Camila"
                    materia: "Programación"

            # =====================================================
            # RIGHT COLUMN END
            # =====================================================

        # =========================================================
        # BODY END
        # =========================================================