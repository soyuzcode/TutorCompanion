#:import dp kivy.metrics.dp

<DashboardScreen>:

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.08, 0.09, 0.12, 1

        # ===== HEADER =====

        MDCard:
            size_hint_y: None
            height: dp(90)
            radius: [0, 0, 25, 25]
            elevation: 0
            padding: dp(20)
            md_bg_color: 0.05, 0.08, 0.16, 1

            MDBoxLayout:
                spacing: dp(20)

                # ===== USER =====

                MDBoxLayout:
                    adaptive_width: True
                    spacing: dp(15)

                    MDIcon:
                        icon: "account-circle"
                        font_size: "42sp"
                        theme_text_color: "Custom"
                        text_color: 0.3, 0.8, 1, 1

                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True

                        MDLabel:
                            text: "Hola Carlitos 👋"
                            bold: True
                            font_name: "Emoji"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                        MDLabel:
                            text: "Rol: Estudiante"
                            theme_text_color: "Custom"
                            text_color: 0.7, 0.7, 0.7, 1

                Widget:

                # ===== CENTER =====

                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_width: True

                    MDLabel:
                        text: "Compañeros Tutores"
                        halign: "center"
                        bold: True
                        font_size: "24sp"
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                    MDLabel:
                        text: "Tu red de aprendizaje"
                        halign: "center"
                        theme_text_color: "Custom"
                        text_color: 0.7, 0.7, 0.7, 1

                Widget:

                # ===== ACTIONS =====

                MDBoxLayout:
                    adaptive_width: True
                    spacing: dp(10)

                    MDIconButton:
                        icon: "bell-outline"
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                    MDIconButton:
                        icon: "calendar"
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

        # ===== BODY =====

        MDBoxLayout:
            padding: dp(20)
            spacing: dp(20)

            # =========================================================
            # LEFT COLUMN
            # =========================================================

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.33

                MDLabel:
                    text: "¿Qué quieres hacer?"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                ActionCard:
                    icon: "calendar-plus"
                    title: "Sugerir Tutoría"
                    subtitle: "Pide ayuda en temas difíciles"

                ActionCard:
                    icon: "magnify"
                    title: "Buscar Tutorías"
                    subtitle: "Explora tutorías disponibles"

                ActionCard:
                    icon: "clock-outline"
                    title: "Mis Tutorías"
                    subtitle: "Revisa tus sesiones"

                MDLabel:
                    text: "Próximas Tutorías"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                TutoriaCard:
                    materia: "Cálculo I"
                    estado: "Confirmada"

                TutoriaCard:
                    materia: "Física"
                    estado: "Pendiente"

            # =========================================================
            # CENTER COLUMN
            # =========================================================

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.33

                MDLabel:
                    text: "Tutores Destacados"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                TutorCard:
                    position: "1"
                    name: "Andrea"

                TutorCard:
                    position: "2"
                    name: "Sebastián"

                TutorCard:
                    position: "3"
                    name: "María"

                TutorCard:
                    position: "4"
                    name: "Carlos"

                MDLabel:
                    text: "Feedback y progreso"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                MDGridLayout:
                    cols: 2
                    spacing: dp(15)
                    adaptive_height: True

                    FeatureCard:
                        icon: "star"
                        title: "Rating Tutor"

                    FeatureCard:
                        icon: "chart-bar"
                        title: "Estadísticas"

            # =========================================================
            # RIGHT COLUMN
            # =========================================================

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.34

                MDTextField:
                    hint_text: "Buscar tutorías..."
                    mode: "rectangle"

                MDCard:
                    padding: dp(20)
                    radius: [20]
                    elevation: 0
                    md_bg_color: 0.12, 0.13, 0.18, 1
                    size_hint_y: None
                    height: dp(170)

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(12)

                        MDLabel:
                            text: "Tu impacto como tutor"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                        MDLabel:
                            text: "⏰ Key Hours: 24"
                            font_name: "Emoji"
                            theme_text_color: "Custom"
                            text_color: 0.8, 0.8, 0.8, 1

                        MDLabel:
                            text: "¡Sigue enseñando y canjea horas!"
                            theme_text_color: "Custom"
                            text_color: 0.6, 0.6, 0.6, 1

                        MDProgressBar:
                            value: 70

                MDLabel:
                    text: "Solicitudes"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                SolicitudCard:
                    name: "Luis"
                    materia: "Álgebra"

                SolicitudCard:
                    name: "Camila"
                    materia: "Programación"

                MDLabel:
                    text: "Calendario"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                CalendarCard: