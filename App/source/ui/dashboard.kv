#:import dp kivy.metrics.dp

# =========================================================
# DASHBOARD SCREEN
# =========================================================

<DashboardScreen>:

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.08, 0.09, 0.12, 1

        # =========================================================
        # HEADER START
        # =========================================================

        MDCard:
            size_hint_y: None
            height: dp(110)

            radius: [0, 0, 25, 25]
            elevation: 0
            padding: dp(20)

            md_bg_color: 0.05, 0.08, 0.16, 1

            MDBoxLayout:
                spacing: dp(20)

                # =================================================
                # USER SECTION START
                # =================================================

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_x: 0.3
                    spacing: dp(15)

                    MDIcon:
                        icon: "account-circle"
                        font_size: "52sp"

                        size_hint_x: None
                        width: dp(55)

                        theme_text_color: "Custom"
                        text_color: 0.3, 0.8, 1, 1

                    MDBoxLayout:
                        orientation: "vertical"

                        Widget:

                        MDLabel:
                            id: label_nombre
                            text: "Hola, Usuario"
                            bold: True
                            adaptive_height: True

                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                        MDLabel:
                            id: label_rol
                            text: "Rol: Activo"
                            adaptive_height: True

                            theme_text_color: "Custom"
                            text_color: 0.7, 0.7, 0.7, 1

                        Widget:

                # =================================================
                # USER SECTION END
                # =================================================


                # =================================================
                # CENTER TITLE START
                # =================================================

                MDBoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.5

                    Widget:

                    MDLabel:
                        text: "Tutor Companion"

                        halign: "center"
                        bold: True

                        font_size: "26sp"

                        adaptive_height: True

                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                    MDLabel:
                        text: "Tu red de aprendizaje"

                        halign: "center"

                        adaptive_height: True

                        theme_text_color: "Custom"
                        text_color: 0.7, 0.7, 0.7, 1

                    Widget:

                # =================================================
                # CENTER TITLE END
                # =================================================


                # =================================================
                # ACTIONS START
                # =================================================

                MDBoxLayout:
                    size_hint_x: 0.2

                    Widget:

                    MDIconButton:
                        icon: "bell-outline"

                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                    MDIconButton:
                        icon: "calendar"

                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                # =================================================
                # ACTIONS END
                # =================================================

        # =========================================================
        # HEADER END
        # =========================================================



        # =========================================================
        # BODY START
        # =========================================================

        MDBoxLayout:
            padding: dp(20)
            spacing: dp(20)

           # =====================================================
            # LEFT COLUMN START
            # =====================================================
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.33

                MDLabel:
                    text: "¿Qué quieres hacer?"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                ActionCard:
                    icon: "calendar-plus"
                    title: "Sugerir Tutoría"
                    subtitle: "Pide ayuda en temas difíciles"
                    ripple_behavior: True
                    on_release: root.ir_a_sugerir_tutoria()

                #ActionCard:
                    #icon: "magnify"
                    #title: "Buscar Tutorías"
                    #subtitle: "Explora tutorías disponibles"
                    #ripple_behavior: True
                    #on_release: root.ir_a_buscar_tutorias()

                ActionCard:
                    icon: "clock-outline"
                    title: "Mis Tutorías"
                    subtitle: "Revisa tus sesiones"
                    ripple_behavior: True
                    on_release: root.ir_a_mis_tutorias()

                MDLabel:
                    text: "Próximas Tutorías"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                ScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    bar_width: dp(4)

                    MDBoxLayout:
                        id: contenedor_izquierdo
                        orientation: "vertical"
                        spacing: dp(15)
                        size_hint_y: None
                        height: self.minimum_height

            # =====================================================
            # LEFT COLUMN END
            # =====================================================

            # =====================================================
            # CENTER COLUMN START
            # =====================================================

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.33

                MDLabel:
                    text: "Tutores Destacados"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                MDBoxLayout:
                    id: tutor_container
                    orientation: "vertical"
                    spacing: dp(15)
                    adaptive_height: True

                MDLabel:
                    text: "Feedback y progreso"
                    bold: True
                    font_size: "22sp"
                    adaptive_height: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                MDGridLayout:
                    cols: 1
                    spacing: dp(15)
                    adaptive_height: True

                    FeatureCard:
                        icon: "star"
                        title: "Rating Tutor"
                        ripple_behavior: True
                        on_release: root.ver_ratings()

                    #FeatureCard:
                    #    icon: "chart-bar"
                    #    title: "Estadísticas"
                    #    ripple_behavior: True
                    #    on_release: root.ver_estadisticas()

            # =====================================================
            # CENTER COLUMN END
            # =====================================================

            # =====================================================
            # RIGHT COLUMN START
            # =====================================================
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(15)
                size_hint_x: 0.34

                ImpactCard:
                    id: impact_card
                    current_hours: 24
                    total_hours: 40
                    progress_value: 60

                ScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    bar_width: dp(4)

                    MDBoxLayout:
                        id: contenedor_solicitudes
                        orientation: "vertical"
                        spacing: dp(15)
                        adaptive_height: True

                        MDLabel:
                            text: "Solicitudes"
                            bold: True
                            font_size: "22sp"
                            adaptive_height: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

            # =====================================================
            # RIGHT COLUMN END
            # =====================================================